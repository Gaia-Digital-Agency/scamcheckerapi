# Copy to .env and fill in. Never commit .env.

# Your own API key — share this with consumers (e.g. WordPress).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SCAMCHECK_API_KEY=

# Postgres (dedicated scamcheck DB on gda-s01)
DATABASE_URL=postgresql://scamcheck:PASSWORD@127.0.0.1:5432/scamcheck

# Bind (behind nginx → keep on localhost)
HOST=127.0.0.1
PORT=8080

# Comma-separated allowed browser origins (WordPress domain, etc.). Empty = allow all.
ALLOWED_ORIGINS=

# Provider keys (free tiers). At least IPQS recommended.
IPQS_API_KEY=
NUMVERIFY_API_KEY=
ABSTRACT_API_KEY=

# Tuning
CACHE_TTL_DAYS=30
RATE_LIMIT_MAX=60
RATE_LIMIT_WINDOW_MIN=15
